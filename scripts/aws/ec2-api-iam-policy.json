{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "RembehS3Media",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:AbortMultipartUpload",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::rembeh-prod-bucket",
        "arn:aws:s3:::rembeh-prod-bucket/*"
      ]
    }
  ]
}
