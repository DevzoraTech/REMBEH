NODE_ENV=development

# API
PORT=4000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000
WEB_APP_URL=http://localhost:3000
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
# Local development only. Keep false or unset outside trusted dev machines.
AUTH_PHONE_OTP_DEV_MODE=true
OTP_EMAIL_FROM=auth@antikra.com
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_RESENDS=3

# Data services
# Local Docker Postgres by default. Production will use AWS RDS.
DATABASE_URL=postgresql://rembeh:rembeh@localhost:5432/rembeh?schema=public
REDIS_URL=redis://localhost:6379
# Object storage: leave S3_ENDPOINT empty for real AWS S3.
# Local MinIO example:
#   S3_ENDPOINT=http://localhost:9000
#   S3_PUBLIC_ENDPOINT=http://192.168.x.x:9000
#   S3_BUCKET=rembeh-local
S3_ENDPOINT=
S3_PUBLIC_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Prefer same region as RDS (e.g. eu-north-1) for lower latency.
S3_REGION=eu-north-1
# Production target:
# - API: AWS EC2 (same region as RDS)
# - Database: AWS RDS PostgreSQL
# - Files: AWS S3
# - Web: Amplify / S3+CloudFront / ECS

# Smile ID (NIN / Enhanced KYC). When unset or SMILE_ID_ENABLED=false, API uses a local stub.
SMILE_ID_ENABLED=false
SMILE_ID_PARTNER_ID=
SMILE_ID_API_KEY=
SMILE_ID_BASE_URL=https://api.smileidentity.com/v1
SMILE_ID_CALLBACK_URL=

# Realtime (Socket.IO)
REALTIME_CORS_ORIGIN=*

# Notifications
EMAIL_FROM=auth@antikra.com
RESEND_API_KEY=
SMS_PROVIDER=mock
WHATSAPP_PROVIDER=mock
